-func (s *Service) Create(ctx context.Context, accountID string, request CreateRequest) (Payment, error) {
-	if accountID == "" || !request.Valid() {
+func (s *Service) Create(ctx context.Context, accountID, idempotencyKey string, request CreateRequest) (Payment, error) {
+	if accountID == "" || idempotencyKey == "" || !request.Valid() {
 		return Payment{}, ErrInvalidRequest
 	}
 
+	record, found, err := s.repository.FindPaymentByIdempotencyKey(ctx, idempotencyKey)
+	if err != nil {
+		return Payment{}, err
+	}
+	if found {
+		if !record.Matches(request) {
+			return Payment{}, ErrIdempotencyConflict
+		}
+		if err := s.recordCreated(ctx, record.Payment); err != nil {
+			return Payment{}, err
+		}
+		return record.Payment, nil
+	}
+
 	created := Payment{
 		ID:        s.newID(),
 		AccountID: accountID,
 		Amount:    request.Amount,
 		Currency:  request.Currency,
 	}
-	if err := s.repository.SavePayment(ctx, created); err != nil {
+	if err := s.repository.SavePayment(ctx, created, idempotencyKey, request); err != nil {
 		return Payment{}, err
 	}
-	if err := s.repository.RecordAudit(ctx, audit.Entry{
-		Kind:        "payment.created",
-		AggregateID: created.ID,
-		AccountID:   accountID,
-		At:          s.now(),
-	}); err != nil {
+	if err := s.recordCreated(ctx, created); err != nil {
 		return Payment{}, err
 	}
 	return created, nil
 }
+
+func (s *Service) recordCreated(ctx context.Context, created Payment) error {
+	return s.repository.RecordAudit(ctx, audit.Entry{
+		Kind:        "payment.created",
+		AggregateID: created.ID,
+		AccountID:   created.AccountID,
+		At:          s.now(),
+	})
+}
