diff --git a/internal/payment/idempotency.go b/internal/payment/idempotency.go
new file mode 100644
--- /dev/null
+++ b/internal/payment/idempotency.go
@@ -0,0 +1,14 @@
+package payment
+
+import "errors"
+
+var ErrIdempotencyConflict = errors.New("idempotency key conflicts with an existing payment")
+
+type IdempotencyRecord struct {
+	Payment Payment
+	Request CreateRequest
+}
+
+func (r IdempotencyRecord) Matches(request CreateRequest) bool {
+	return r.Request.Amount == request.Amount && r.Request.Currency == request.Currency
+}
