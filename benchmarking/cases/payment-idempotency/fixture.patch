+func TestCreatePaymentReplaysAndConflicts(t *testing.T) {
+	repository := store.NewMemory()
+	nextID := 0
+	service := payment.NewService(repository, func() string {
+		nextID++
+		return "pay-" + string(rune('0'+nextID))
+	}, time.Now)
+	request := payment.CreateRequest{Amount: 1250, Currency: "USD"}
+
+	first, err := service.Create(context.Background(), "acct-1", "key-1", request)
+	if err != nil {
+		t.Fatal(err)
+	}
+	replayed, err := service.Create(context.Background(), "acct-1", "key-1", request)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if replayed.ID != first.ID {
+		t.Fatalf("replayed = %#v, first = %#v", replayed, first)
+	}
+	_, err = service.Create(context.Background(), "acct-1", "key-1", payment.CreateRequest{
+		Amount: 1300, Currency: "USD",
+	})
+	if !errors.Is(err, payment.ErrIdempotencyConflict) {
+		t.Fatalf("conflict error = %v", err)
+	}
+}
