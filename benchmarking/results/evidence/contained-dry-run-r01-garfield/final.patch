+func TestDryRunDoesNotMutateInvoice(t *testing.T) {
+	now := time.Date(2026, time.July, 13, 12, 0, 0, 0, time.UTC)
+	repository := &recordingRepository{Memory: store.NewMemory()}
+	repository.SeedInvoice(invoice.Invoice{
+		ID: "inv-1", AccountID: "acct-1", DueAt: now.Add(-time.Hour), Status: invoice.StatusPending,
+	})
+
+	service := invoice.NewService(repository, func() time.Time { return now })
+	matches, err := service.Expire(context.Background(), now, true)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if len(matches) != 1 || matches[0].ID != "inv-1" {
+		t.Fatalf("matches = %#v", matches)
+	}
+	if matches[0].Status != invoice.StatusPending {
+		t.Fatalf("reported status = %q", matches[0].Status)
+	}
+	stored, ok := repository.Invoice("inv-1")
+	if !ok {
+		t.Fatal("invoice missing")
+	}
+	if stored.Status != invoice.StatusPending {
+		t.Fatalf("status = %q", stored.Status)
+	}
+	if repository.saveCalls != 0 {
+		t.Fatalf("save calls = %d", repository.saveCalls)
+	}
+	if got := len(repository.AuditEntries()); got != 0 {
+		t.Fatalf("audit entries = %d", got)
+	}
+}
