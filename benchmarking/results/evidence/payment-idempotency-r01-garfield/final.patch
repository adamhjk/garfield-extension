+		}
+	}
+
+	differentKey := payment.Payment{ID: "pay-4", AccountID: "acct-1", Amount: 1250, Currency: "USD"}
+	third, err := repository.CreatePayment(context.Background(), differentKey, "key-2", createdAt)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if third != differentKey {
+		t.Fatalf("third = %#v", third)
+	}
+
+	otherAccount := payment.Payment{ID: "pay-5", AccountID: "acct-2", Amount: 1250, Currency: "USD"}
+	second, err := repository.CreatePayment(context.Background(), otherAccount, "key-1", createdAt)
+	if err != nil {
