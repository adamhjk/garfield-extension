+func TestCreatePaymentConcurrentReplaysAreAtomic(t *testing.T) {
+	repository := store.NewMemory()
+	var nextID atomic.Int64
+	service := payment.NewService(repository, func() string {
+		return fmt.Sprintf("pay-%d", nextID.Add(1))
+	}, time.Now)
+	request := payment.CreateRequest{Amount: 1250, Currency: "USD"}
+
+	const callers = 16
+	type result struct {
+		payment payment.Payment
+		err     error
+	}
+	results := make(chan result, callers)
+	start := make(chan struct{})
+	var group sync.WaitGroup
+	for range callers {
+		group.Add(1)
+		go func() {
+			defer group.Done()
+			<-start
+			created, err := service.Create(context.Background(), "acct-1", "key-1", request)
+			results <- result{payment: created, err: err}
+		}()
+	}
+	close(start)
+	group.Wait()
+	close(results)
+
+	var original payment.Payment
+	for result := range results {
+		if result.err != nil {
+			t.Fatal(result.err)
+		}
+		if original.ID == "" {
+			original = result.payment
+		}
+		if result.payment != original {
+			t.Fatalf("payment = %#v, original = %#v", result.payment, original)
+		}
+	}
+	if got := len(repository.AuditEntries()); got != 1 {
+		t.Fatalf("audit entries = %d", got)
+	}
+}
+
+func TestCreatePaymentConcurrentDifferentInputConflicts(t *testing.T) {
+	repository := store.NewMemory()
+	var nextID atomic.Int64
+	service := payment.NewService(repository, func() string {
+		return fmt.Sprintf("pay-%d", nextID.Add(1))
+	}, time.Now)
+
+	requests := []payment.CreateRequest{
+		{Amount: 1250, Currency: "USD"},
+		{Amount: 1300, Currency: "USD"},
+	}
+	errorsByRequest := make(chan error, len(requests))
+	start := make(chan struct{})
+	var group sync.WaitGroup
+	for _, request := range requests {
+		group.Add(1)
+		go func() {
+			defer group.Done()
+			<-start
+			_, err := service.Create(context.Background(), "acct-1", "key-1", request)
+			errorsByRequest <- err
+		}()
+	}
+	close(start)
+	group.Wait()
+	close(errorsByRequest)
+
+	succeeded, conflicted := 0, 0
+	for err := range errorsByRequest {
+		switch {
+		case err == nil:
+			succeeded++
+		case errors.Is(err, payment.ErrIdempotencyConflict):
+			conflicted++
+		default:
+			t.Fatalf("unexpected error = %v", err)
+		}
+	}
+	if succeeded != 1 || conflicted != 1 {
+		t.Fatalf("succeeded = %d, conflicted = %d", succeeded, conflicted)
+	}
+	if got := len(repository.AuditEntries()); got != 1 {
+		t.Fatalf("audit entries = %d", got)
+	}
+}
