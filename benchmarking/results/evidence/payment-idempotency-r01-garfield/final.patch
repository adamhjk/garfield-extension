+func TestCreatePaymentIsIdempotentAndAccountScoped(t *testing.T) {
+	repository := store.NewMemory()
+	createdAt := time.Date(2026, time.July, 14, 0, 0, 0, 0, time.UTC)
+	created := payment.Payment{ID: "pay-1", AccountID: "acct-1", Amount: 1250, Currency: "USD"}
+	first, err := repository.CreatePayment(context.Background(), created, "key-1", createdAt)
+	if err != nil {
+		t.Fatal(err)
+	}
+	replayed, err := repository.CreatePayment(context.Background(), payment.Payment{
+		ID: "pay-2", AccountID: "acct-1", Amount: 1250, Currency: "USD",
+	}, "key-1", createdAt.Add(time.Hour))
+	if err != nil {
+		t.Fatal(err)
+	}
+	if first != created || replayed != created {
+		t.Fatalf("first = %#v, replayed = %#v", first, replayed)
+	}
+
+	_, err = repository.CreatePayment(context.Background(), payment.Payment{
+		ID: "pay-3", AccountID: "acct-1", Amount: 1300, Currency: "USD",
+	}, "key-1", createdAt.Add(time.Hour))
+	if !errors.Is(err, payment.ErrIdempotencyConflict) {
+		t.Fatalf("conflict error = %v", err)
+	}
