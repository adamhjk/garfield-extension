+func TestCreatePaymentConflict(t *testing.T) {
+	repository := store.NewMemory()
+	service := payment.NewService(repository, func() string { return "pay-1" }, time.Now)
+	handler := api.NewHandler(service)
+
+	first := httptest.NewRequest(http.MethodPost, "/accounts/acct-1/payments", bytes.NewBufferString(`{"amount":1250,"currency":"USD"}`))
