+func TestIdempotencyLookupReturnsStoredPayment(t *testing.T) {
+	repository := store.NewMemory()
+	created := payment.Payment{ID: "pay-1", AccountID: "acct-1", Amount: 1250, Currency: "USD"}
+	request := payment.CreateRequest{Amount: 1250, Currency: "USD"}
+	entry := audit.Entry{Kind: "payment.created", AggregateID: created.ID, AccountID: created.AccountID}
+	if _, saved, err := repository.SavePayment(context.Background(), created, "key-1", request, entry); err != nil {
+		t.Fatal(err)
+	} else if !saved {
+		t.Fatal("payment was not saved")
+	}
+	record, ok, err := repository.FindPaymentByIdempotencyKey(context.Background(), "acct-1", "key-1")
+	if err != nil {
+		t.Fatal(err)
+	}
+	if !ok || record.Payment.ID != created.ID || !record.Matches(request) {
+		t.Fatalf("record = %#v, ok = %v", record, ok)
+	}
+
+	duplicate := payment.Payment{ID: "pay-2", AccountID: "acct-1", Amount: 1300, Currency: "USD"}
+	duplicateRequest := payment.CreateRequest{Amount: 1300, Currency: "USD"}
+	duplicateRecord, saved, err := repository.SavePayment(context.Background(), duplicate, "key-1", duplicateRequest, audit.Entry{
+		Kind: "payment.created", AggregateID: duplicate.ID, AccountID: duplicate.AccountID,
+	})
+	if err != nil {
+		t.Fatal(err)
+	}
+	if saved || duplicateRecord.Payment.ID != created.ID {
+		t.Fatalf("duplicate record = %#v, saved = %v", duplicateRecord, saved)
+	}
+	if _, ok := repository.Payment(duplicate.ID); ok {
+		t.Fatal("duplicate payment was persisted")
+	}
+	if got := len(repository.AuditEntries()); got != 1 {
+		t.Fatalf("audit entries after duplicate = %d", got)
+	}
+
+	otherAccount := payment.Payment{ID: "pay-3", AccountID: "acct-2", Amount: 1300, Currency: "USD"}
+	if _, saved, err := repository.SavePayment(context.Background(), otherAccount, "key-1", duplicateRequest, audit.Entry{
+		Kind: "payment.created", AggregateID: otherAccount.ID, AccountID: otherAccount.AccountID,
+	}); err != nil {
+		t.Fatal(err)
+	} else if !saved {
+		t.Fatal("same key was not independent in another account")
+	}
+	if got := len(repository.AuditEntries()); got != 2 {
+		t.Fatalf("audit entries after other account = %d", got)
+	}
+}
